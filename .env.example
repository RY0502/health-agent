PORT=3017
LOCALE=en-us
DEFAULT_TOP_N=5
MAX_WEB_RESULTS_PER_QUERY=8
MAX_FETCHED_DOCS=250
MAX_IMAGE_CANDIDATES_PER_REMEDY=250
OUTPUT_ROOT=./outputs
USE_PLAYWRIGHT_FALLBACK=true

# Optional Hugging Face Inference API configuration for surgical text + vision reasoning
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_TEXT_MODEL=Qwen/Qwen2.5-3B-Instruct
HF_VISION_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
ENABLE_HF_TEXT_REASONING=true
ENABLE_HF_VISION_REASONING=true
